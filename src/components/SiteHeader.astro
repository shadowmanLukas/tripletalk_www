---
type Page = "home" | "terms" | "privacy" | "support";

interface Props {
  currentPage?: Page;
}

const { currentPage = "home" } = Astro.props;
const sectionPrefix = currentPage === "home" ? "" : "/";
---

<header class="site-header">
  <nav class="container nav" aria-label="Main navigation">
    <a class="brand" href="/" aria-label="TripleTalk home">
      <img src="/assets/tripletalk-logo.png" alt="" width="40" height="40" />
      <span><span>Triple</span><span>Talk</span></span>
    </a>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu">
      <span class="sr-only">Open menu</span>
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="nav-links" id="site-menu">
      <a href={`${sectionPrefix}#features`} data-i18n="navFeatures">Features</a>
      <a href={`${sectionPrefix}#download`} data-i18n="navDownload">Download</a>
      <a href="/terms" data-i18n="navTerms" aria-current={currentPage === "terms" ? "page" : undefined}>Terms</a>
      <a href="/privacy" data-i18n="navPrivacy" aria-current={currentPage === "privacy" ? "page" : undefined}>
        Privacy
      </a>
      <div class="language-switcher">
        <button
          class="language-menu-trigger"
          type="button"
          aria-expanded="false"
          aria-controls="language-menu"
          aria-label="Choose language"
        >
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M3 12h18M12 3c2.4 2.5 3.7 5.5 3.7 9S14.4 18.5 12 21M12 3C9.6 5.5 8.3 8.5 8.3 12s1.3 6.5 3.7 9"></path>
          </svg>
        </button>
        <div class="language-menu" id="language-menu" role="menu" hidden>
          <button type="button" role="menuitemradio" data-lang-switch="en">
            <span>English</span>
          </button>
          <button type="button" role="menuitemradio" data-lang-switch="pl">
            <span>Polski</span>
          </button>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const languageSwitcher = document.querySelector<HTMLElement>(".language-switcher");
  const languageTrigger = languageSwitcher?.querySelector<HTMLButtonElement>(".language-menu-trigger");
  const languageMenu = languageSwitcher?.querySelector<HTMLElement>(".language-menu");
  const languageOptions = languageSwitcher?.querySelectorAll<HTMLButtonElement>("[data-lang-switch]");

  function closeLanguageMenu() {
    languageTrigger?.setAttribute("aria-expanded", "false");
    if (languageMenu) languageMenu.hidden = true;
  }

  languageTrigger?.addEventListener("click", () => {
    const shouldOpen = languageTrigger.getAttribute("aria-expanded") !== "true";
    languageTrigger.setAttribute("aria-expanded", String(shouldOpen));
    if (languageMenu) languageMenu.hidden = !shouldOpen;
  });

  languageOptions?.forEach((option) => {
    option.addEventListener("click", () => {
      closeLanguageMenu();
    });
  });

  document.addEventListener("click", (event) => {
    if (event.target instanceof Node && !languageSwitcher?.contains(event.target)) {
      closeLanguageMenu();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeLanguageMenu();
      languageTrigger?.focus();
    }
  });
</script>

---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Need help with TripleTalk? Contact us about the app, your account, privacy or data requests."
    />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tripletalk.app/support/" />
    <meta property="og:title" content="TripleTalk Support" />
    <meta
      property="og:description"
      content="Need help with TripleTalk? Contact us about the app, your account, privacy or data requests."
    />
    <meta property="og:image" content="https://tripletalk.app/assets/tripletalk-logo-with-background.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="TripleTalk Support" />
    <meta
      name="twitter:description"
      content="Need help with TripleTalk? Contact us about the app, your account, privacy or data requests."
    />
    <meta name="twitter:image" content="https://tripletalk.app/assets/tripletalk-logo-with-background.png" />
    <title>TripleTalk Support</title>
    <link rel="canonical" href="https://tripletalk.app/support/" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/tripletalk-logo.png" />
  </head>
  <body class="support-body">
    <SiteHeader currentPage="support" />

    <main class="support-page">
      <section class="support-hero" aria-labelledby="support-title">
        <div class="container">
          <div class="support-card">
            <p class="eyebrow" data-i18n="supportEyebrow">TripleTalk Support</p>
            <h1 id="support-title" data-i18n="supportTitle">How can we help?</h1>
            <p class="support-intro" data-i18n="supportIntro">
              Need help with TripleTalk? Contact us about the app, your account, privacy or data requests.
            </p>

            <div class="support-contact" aria-label="Support email">
              <span data-i18n="emailLabel">Email</span>
              <!--email_off-->
              <strong class="support-email">support@tripletalk.app</strong>
              <!--/email_off-->
              <p class="support-response" data-i18n="responseTime">We usually reply within 1–2 business days.</p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <SiteFooter currentPage="support" />

    <script>
      const translations = {
        pl: {
          navFeatures: "Funkcje",
          navDownload: "Pobierz",
          navTerms: "Regulamin",
          navPrivacy: "Prywatność",
          supportEyebrow: "Pomoc TripleTalk",
          supportTitle: "Jak możemy pomóc?",
          supportIntro:
            "Potrzebujesz pomocy z TripleTalk? Skontaktuj się z nami w sprawie aplikacji, konta, prywatności lub wniosków dotyczących danych.",
          emailLabel: "E-mail",
          responseTime: "Zwykle odpowiadamy w ciągu 1–2 dni roboczych.",
          footerPrivacy: "Polityka Prywatności",
          footerTerms: "Regulamin",
          footerSupport: "Pomoc",
          pageTitle: "Pomoc TripleTalk",
        },
        en: {
          navFeatures: "Features",
          navDownload: "Download",
          navTerms: "Terms",
          navPrivacy: "Privacy",
          supportEyebrow: "TripleTalk Support",
          supportTitle: "How can we help?",
          supportIntro:
            "Need help with TripleTalk? Contact us about the app, your account, privacy or data requests.",
          emailLabel: "Email",
          responseTime: "We usually reply within 1–2 business days.",
          footerPrivacy: "Privacy Policy",
          footerTerms: "Terms of Service",
          footerSupport: "Support",
          pageTitle: "TripleTalk Support",
        },
      };

      const menuToggle = document.querySelector(".menu-toggle");
      const navLinks = document.querySelector(".nav-links");
      const languageButtons = document.querySelectorAll("[data-lang-switch]");
      const translatedNodes = document.querySelectorAll("[data-i18n]");

      const savedLanguage = localStorage.getItem("tripletalk-language-preference");
      const initialLanguage = savedLanguage === "pl" || savedLanguage === "en" ? savedLanguage : "en";

      function setLanguage(language: "pl" | "en") {
        document.documentElement.lang = language;
        document.title = translations[language].pageTitle;

        translatedNodes.forEach((node) => {
          const key = node.getAttribute("data-i18n");
          if (key && key in translations[language]) {
            node.textContent = translations[language][key as keyof (typeof translations)["pl"]];
          }
        });

        languageButtons.forEach((button) => {
          const isActive = button.getAttribute("data-lang-switch") === language;
          button.classList.toggle("active", isActive);
          button.setAttribute("aria-checked", String(isActive));
        });

        localStorage.setItem("tripletalk-language-preference", language);
      }

      menuToggle?.addEventListener("click", () => {
        const expanded = menuToggle.getAttribute("aria-expanded") === "true";
        menuToggle.setAttribute("aria-expanded", String(!expanded));
        navLinks?.classList.toggle("open", !expanded);
      });

      navLinks?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          menuToggle?.setAttribute("aria-expanded", "false");
          navLinks.classList.remove("open");
        });
      });

      languageButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const language = button.getAttribute("data-lang-switch");
          if (language === "pl" || language === "en") setLanguage(language);
        });
      });

      setLanguage(initialLanguage);
    </script>
  </body>
</html>

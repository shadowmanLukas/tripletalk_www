const documents = [
  {
    id: "pl",
    label: "PL",
    pageTitle: "Regulamin",
    title: "Regulamin korzystania z aplikacji TripleTalk",
    effectiveDate: "Data obowiązywania: 2 lipca 2026",
    sections: polishSections,
  },
  {
    id: "en",
    label: "EN",
    pageTitle: "Terms of Service",
    title: "TripleTalk Terms of Service",
    effectiveDate: "Effective date: July 2, 2026",
    sections: englishSections,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="TripleTalk Terms of Service and Polish terms for the TripleTalk mobile application."
    />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tripletalk.app/terms/" />
    <meta property="og:title" content="Terms of Service - TripleTalk" />
    <meta property="og:description" content="Terms of Service for the TripleTalk mobile application." />
    <meta property="og:image" content="https://tripletalk.app/assets/tripletalk-logo-with-background.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Terms of Service - TripleTalk" />
    <meta name="twitter:description" content="Terms of Service for the TripleTalk mobile application." />
    <meta name="twitter:image" content="https://tripletalk.app/assets/tripletalk-logo-with-background.png" />
    <title>Terms of Service - TripleTalk</title>
    <link rel="canonical" href="https://tripletalk.app/terms/" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/tripletalk-logo.png" />
  </head>
  <body>
    <main class="legal-page legal-page--terms">
      <div class="container legal-shell">
        <header class="legal-hero">
          <a class="brand legal-brand" href="/" aria-label="TripleTalk home">
            <img src="/assets/tripletalk-logo.png" alt="" width="40" height="40" />
            <span><span>Triple</span><span>Talk</span></span>
          </a>
          <div class="legal-hero-copy">
            <h1 data-legal-title data-pl={documents[0].pageTitle} data-en={documents[1].pageTitle}>
              {documents[1].pageTitle}
            </h1>
          </div>
          <div class="legal-toolbar" aria-label="Terms language selector">
            {
              documents.map((document) => (
                <button
                  class={document.id === "en" ? "active" : ""}
                  type="button"
                  data-legal-language={document.id}
                  aria-pressed={document.id === "en"}
                >
                  {document.label}
                </button>
              ))
            }
          </div>
        </header>

        <div class="legal-documents">
          {
            documents.map((document) => (
              <article class="legal-document" id={document.id} lang={document.id} hidden={document.id !== "en"}>
                <div class="legal-document-header">
                  <div>
                    <h2>{document.title}</h2>
                    <p>{document.effectiveDate}</p>
                  </div>
                </div>

                <div class="legal-sections">
                  {
                    document.sections.map((section, index) => (
                      <section class="legal-section" id={`${document.id}-${index + 1}`}>
                        <h3>
                          <span>{index + 1}</span>
                          {section.title}
                        </h3>
                        {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
                        {
                          section.items && (
                            <ul>
                              {section.items.map((item) => (
                                <li>{item}</li>
                              ))}
                            </ul>
                          )
                        }
                        {section.closing?.map((paragraph) => <p>{paragraph}</p>)}
                      </section>
                    ))
                  }
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </main>
    <script>
      const legalLanguageButtons = document.querySelectorAll("[data-legal-language]");
      const legalDocuments = document.querySelectorAll<HTMLElement>(".legal-document");
      const legalTitle = document.querySelector("[data-legal-title]");
      const savedLegalLanguage = localStorage.getItem("tripletalk-language");
      const initialLegalLanguage = savedLegalLanguage === "pl" || savedLegalLanguage === "en" ? savedLegalLanguage : "en";

      function setLegalLanguage(language: string) {
        document.documentElement.lang = language;

        legalLanguageButtons.forEach((button) => {
          const isActive = button.getAttribute("data-legal-language") === language;
          button.classList.toggle("active", isActive);
          button.setAttribute("aria-pressed", String(isActive));
        });

        legalDocuments.forEach((document: HTMLElement) => {
          document.hidden = document.id !== language;
        });

        if (legalTitle) {
          legalTitle.textContent = legalTitle.getAttribute(`data-${language}`);
        }

        localStorage.setItem("tripletalk-language", language);
      }

      legalLanguageButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const language = button.getAttribute("data-legal-language");
          if (language) setLegalLanguage(language);
        });
      });

      setLegalLanguage(initialLegalLanguage);
    </script>
  </body>
</html>

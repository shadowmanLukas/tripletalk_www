---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";

const features = [
  {
    title: "Create flashcards in seconds",
    titlePl: "Twórz fiszki w kilka sekund",
    description:
      "Enter a word or add your own content. TripleTalk AI generates translations, examples and audio.",
    descriptionPl:
      "Wpisz słowo lub dodaj własną treść. AI TripleTalk generuje tłumaczenia, przykłady i nagrania audio.",
  },
  {
    title: "Remember words for longer",
    titlePl: "Zapamiętuj słowa na dłużej",
    description: "Smart repetition brings back vocabulary at the right moment, before you forget it.",
    descriptionPl: "Inteligentne powtórki przywracają słownictwo w odpowiednim momencie, zanim je zapomnisz.",
  },
  {
    title: "Learn while you listen",
    titlePl: "Ucz się podczas słuchania",
    description: "Play your lessons as audio while walking, driving or exercising.",
    descriptionPl: "Odtwarzaj lekcje jako audio podczas spaceru, jazdy samochodem lub ćwiczeń.",
  },
  {
    title: "Create your own lessons",
    titlePl: "Twórz własne lekcje",
    description:
      "Create personal vocabulary collections for work, travel, school and everyday conversations.",
    descriptionPl:
      "Twórz własne zestawy słownictwa do pracy, podróży, szkoły i codziennych rozmów.",
  },
];

const steps = [
  {
    number: "01",
    title: "Create",
    titlePl: "Utwórz",
    description: "Add a word, phrase or your own learning material.",
    descriptionPl: "Dodaj słowo, zwrot lub własny materiał do nauki.",
  },
  {
    number: "02",
    title: "Practice",
    titlePl: "Ćwicz",
    description: "Learn with flashcards, examples and audio.",
    descriptionPl: "Ucz się z fiszkami, przykładami i nagraniami audio.",
  },
  {
    number: "03",
    title: "Remember",
    titlePl: "Zapamiętaj",
    description: "Smart repetition schedules the next review automatically.",
    descriptionPl: "Inteligentne powtórki automatycznie planują kolejną sesję.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Create AI-powered flashcards in seconds, learn with smart repetition and audio, and build your vocabulary faster with TripleTalk."
    />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tripletalk.app/" />
    <meta property="og:title" content="TripleTalk – AI Flashcards for Faster Language Learning" />
    <meta
      property="og:description"
      content="Create AI-powered flashcards in seconds, learn with smart repetition and audio, and build your vocabulary faster with TripleTalk."
    />
    <meta property="og:image" content="https://tripletalk.app/assets/tripletalk-logo-with-background.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="TripleTalk – AI Flashcards for Faster Language Learning" />
    <meta
      name="twitter:description"
      content="Create AI-powered flashcards in seconds, learn with smart repetition and audio, and build your vocabulary faster with TripleTalk."
    />
    <meta name="twitter:image" content="https://tripletalk.app/assets/tripletalk-logo-with-background.png" />
    <title>TripleTalk – AI Flashcards for Faster Language Learning</title>
    <link rel="canonical" href="https://tripletalk.app/" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/tripletalk-logo.png" />
  </head>
  <body>
    <SiteHeader currentPage="home" />

    <main>
      <section class="hero">
        <div class="container hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">TripleTalk</p>
            <h1 data-i18n="heroTitle">Build your vocabulary faster with TripleTalk AI Flashcards.</h1>
            <p class="hero-description" data-i18n="heroDescription">
              Create flashcards in seconds with TripleTalk AI. Generate translations, examples and audio automatically,
              then remember new words with smart repetition.
            </p>
            <p class="hero-value" data-i18n="heroValue">
              No more creating flashcards manually. TripleTalk AI does it for you.
            </p>
            <div class="store-actions" aria-label="Download app">
              <a href="TODO" aria-label="Download on the App Store">App Store</a>
              <a href="TODO" aria-label="Get it on Google Play">Google Play</a>
            </div>
          </div>

          <div class="phone-mockup" aria-label="TripleTalk app preview placeholder">
            <div class="phone-frame">
              <div class="phone-speaker"></div>
              <div class="app-screen">
                <div class="screen-top">
                  <span data-i18n="phoneToday">Today</span>
                  <strong>24</strong>
                </div>
                <div class="lesson-card">
                  <span data-i18n="phoneFlashcard">Flashcard</span>
                  <strong>conversation</strong>
                  <p>rozmowa</p>
                </div>
                <div class="mini-list">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="features" aria-labelledby="features-title">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow" data-i18n="featuresEyebrow">Why TripleTalk</p>
            <h2 id="features-title" data-i18n="featuresTitle">
              Everything you need to build vocabulary faster.
            </h2>
          </div>
          <div class="feature-grid">
            {
              features.map((feature) => (
                <article class="feature-card">
                  <h3 data-en={feature.title} data-pl={feature.titlePl}>{feature.title}</h3>
                  <p data-en={feature.description} data-pl={feature.descriptionPl}>{feature.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section how-it-works" aria-labelledby="how-it-works-title">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow" data-i18n="howEyebrow">How it works</p>
            <h2 id="how-it-works-title" data-i18n="howTitle">From a new word to long-term memory.</h2>
          </div>
          <ol class="steps-grid">
            {
              steps.map((step) => (
                <li class="step">
                  <span class="step-number" aria-hidden="true">{step.number}</span>
                  <h3 data-en={step.title} data-pl={step.titlePl}>{step.title}</h3>
                  <p data-en={step.description} data-pl={step.descriptionPl}>{step.description}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section class="section preview-section" aria-labelledby="preview-title">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow" data-i18n="previewEyebrow">App Preview</p>
            <h2 id="preview-title" data-i18n="previewTitle">See how TripleTalk helps you learn.</h2>
          </div>
          <div class="preview-scroll" aria-label="App screenshot placeholders">
            <figure class="screenshot-placeholder">
              <!-- TODO: Replace with real TripleTalk app screenshot. -->
              <div class="screenshot-placeholder-content">
                <div class="placeholder-status"></div>
                <div class="placeholder-card">
                  <span>01</span>
                  <strong data-en="Create with AI" data-pl="Twórz z AI">Create with AI</strong>
                </div>
                <div class="placeholder-lines" aria-hidden="true">
                  <span></span><span></span><span></span>
                </div>
              </div>
            </figure>
            <figure class="screenshot-placeholder">
              <!-- TODO: Replace with real TripleTalk app screenshot. -->
              <div class="screenshot-placeholder-content">
                <div class="placeholder-status"></div>
                <div class="placeholder-card">
                  <span>02</span>
                  <strong data-en="Practice smarter" data-pl="Ćwicz skuteczniej">Practice smarter</strong>
                </div>
                <div class="placeholder-lines" aria-hidden="true">
                  <span></span><span></span><span></span>
                </div>
              </div>
            </figure>
            <figure class="screenshot-placeholder">
              <!-- TODO: Replace with real TripleTalk app screenshot. -->
              <div class="screenshot-placeholder-content">
                <div class="placeholder-status"></div>
                <div class="placeholder-card">
                  <span>03</span>
                  <strong data-en="Learn with audio" data-pl="Ucz się z audio">Learn with audio</strong>
                </div>
                <div class="placeholder-lines" aria-hidden="true">
                  <span></span><span></span><span></span>
                </div>
              </div>
            </figure>
            <figure class="screenshot-placeholder">
              <!-- TODO: Replace with Dashboard / Statistics screenshot. -->
              <div class="screenshot-placeholder-content">
                <div class="placeholder-status"></div>
                <div class="placeholder-card">
                  <span>04</span>
                  <strong data-en="Track your progress" data-pl="Śledź swoje postępy">Track your progress</strong>
                </div>
                <div class="placeholder-lines" aria-hidden="true">
                  <span></span><span></span><span></span>
                </div>
              </div>
            </figure>
          </div>
        </div>
      </section>

      <section class="perfect-for" aria-labelledby="perfect-for-title">
        <div class="container perfect-for-inner">
          <h2 id="perfect-for-title" data-i18n="perfectTitle">Made for every learning goal.</h2>
          <ul>
            <li data-en="Travel" data-pl="Podróże">Travel</li>
            <li data-en="Work" data-pl="Praca">Work</li>
            <li data-en="School" data-pl="Szkoła">School</li>
            <li data-en="Moving abroad" data-pl="Przeprowadzka za granicę">Moving abroad</li>
            <li data-en="Everyday conversations" data-pl="Codzienne rozmowy">Everyday conversations</li>
          </ul>
        </div>
      </section>

      <section class="download" id="download" aria-labelledby="download-title">
        <div class="container download-inner">
          <div class="download-copy">
            <p class="eyebrow" data-i18n="downloadEyebrow">Download</p>
            <h2 id="download-title" data-i18n="downloadTitle">Start building your vocabulary today.</h2>
            <p class="download-description" data-i18n="downloadDescription">
              Download TripleTalk and create your first AI flashcards in minutes.
            </p>
          </div>
          <div class="download-actions">
            <div class="store-actions">
              <a href="TODO" aria-label="Download on the App Store">App Store</a>
              <a href="TODO" aria-label="Get it on Google Play">Google Play</a>
            </div>
            <p class="download-offer" data-i18n="downloadOffer">
              3 days of Premium free · 100 AI flashcards free
            </p>
          </div>
        </div>
      </section>
    </main>

    <SiteFooter currentPage="home" />

    <script>
      const translations = {
        pl: {
          navFeatures: "Funkcje",
          navDownload: "Pobierz",
          navTerms: "Regulamin",
          navPrivacy: "Prywatność",
          heroTitle: "Rozwijaj słownictwo szybciej z fiszkami AI TripleTalk.",
          heroDescription:
            "Twórz fiszki w kilka sekund z AI TripleTalk. Automatycznie generuj tłumaczenia, przykłady i nagrania audio, a następnie zapamiętuj nowe słowa dzięki inteligentnym powtórkom.",
          heroValue: "Koniec z ręcznym tworzeniem fiszek. AI TripleTalk zrobi to za Ciebie.",
          phoneToday: "Dzisiaj",
          phoneFlashcard: "Fiszka",
          featuresEyebrow: "Dlaczego TripleTalk",
          featuresTitle: "Wszystko, czego potrzebujesz, aby szybciej rozwijać słownictwo.",
          howEyebrow: "Jak to działa",
          howTitle: "Od nowego słowa do trwałej pamięci.",
          previewEyebrow: "Podgląd aplikacji",
          previewTitle: "Zobacz, jak TripleTalk pomaga Ci w nauce.",
          perfectTitle: "Dla każdego celu w nauce.",
          downloadEyebrow: "Pobierz",
          downloadTitle: "Zacznij rozwijać swoje słownictwo już dziś.",
          downloadDescription: "Pobierz TripleTalk i utwórz pierwsze fiszki AI w kilka minut.",
          downloadOffer: "3 dni Premium za darmo · 100 fiszek AI za darmo",
          footerPrivacy: "Polityka Prywatności",
          footerTerms: "Regulamin",
          footerSupport: "Pomoc",
        },
        en: {
          navFeatures: "Features",
          navDownload: "Download",
          navTerms: "Terms",
          navPrivacy: "Privacy",
          heroTitle: "Build your vocabulary faster with TripleTalk AI Flashcards.",
          heroDescription:
            "Create flashcards in seconds with TripleTalk AI. Generate translations, examples and audio automatically, then remember new words with smart repetition.",
          heroValue: "No more creating flashcards manually. TripleTalk AI does it for you.",
          phoneToday: "Today",
          phoneFlashcard: "Flashcard",
          featuresEyebrow: "Why TripleTalk",
          featuresTitle: "Everything you need to build vocabulary faster.",
          howEyebrow: "How it works",
          howTitle: "From a new word to long-term memory.",
          previewEyebrow: "App Preview",
          previewTitle: "See how TripleTalk helps you learn.",
          perfectTitle: "Made for every learning goal.",
          downloadEyebrow: "Download",
          downloadTitle: "Start building your vocabulary today.",
          downloadDescription: "Download TripleTalk and create your first AI flashcards in minutes.",
          downloadOffer: "3 days of Premium free · 100 AI flashcards free",
          footerPrivacy: "Privacy Policy",
          footerTerms: "Terms of Service",
          footerSupport: "Support",
        },
      };

      const menuToggle = document.querySelector(".menu-toggle");
      const navLinks = document.querySelector(".nav-links");
      const languageButtons = document.querySelectorAll("[data-lang-switch]");
      const translatedNodes = document.querySelectorAll("[data-i18n]");
      const localizedNodes = document.querySelectorAll("[data-en][data-pl]");

      const languageStorageKey = "tripletalk-language-preference-v2";
      const savedLanguage = localStorage.getItem(languageStorageKey);
      const initialLanguage = savedLanguage === "pl" || savedLanguage === "en" ? savedLanguage : "en";

      function setLanguage(language: "pl" | "en") {
        document.documentElement.lang = language;

        translatedNodes.forEach((node) => {
          const key = node.getAttribute("data-i18n");
          if (key && key in translations[language]) {
            node.textContent = translations[language][key as keyof (typeof translations)["pl"]];
          }
        });

        localizedNodes.forEach((node) => {
          node.textContent = node.getAttribute(`data-${language}`);
        });

        languageButtons.forEach((button) => {
          const isActive = button.getAttribute("data-lang-switch") === language;
          button.classList.toggle("active", isActive);
          button.setAttribute("aria-checked", String(isActive));
        });

        localStorage.setItem(languageStorageKey, language);
      }

      menuToggle?.addEventListener("click", () => {
        const expanded = menuToggle.getAttribute("aria-expanded") === "true";
        menuToggle.setAttribute("aria-expanded", String(!expanded));
        navLinks?.classList.toggle("open", !expanded);
      });

      navLinks?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          menuToggle?.setAttribute("aria-expanded", "false");
          navLinks.classList.remove("open");
        });
      });

      languageButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const language = button.getAttribute("data-lang-switch");
          if (language === "pl" || language === "en") setLanguage(language);
        });
      });

      setLanguage(initialLanguage);
    </script>
  </body>
</html>

---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="TripleTalk landing page." />
    <title>TripleTalk</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <main class="grid min-h-screen place-items-center bg-gradient-to-br from-white via-slate-50 to-sky-50 px-6 text-slate-950">
      <div class="flex flex-col items-center gap-7">
        <img
          src="/assets/tripletalk-logo.png"
          alt="TripleTalk logo"
          class="h-40 w-40 object-contain sm:h-52 sm:w-52"
          width="1024"
          height="1024"
        />
        <h1 class="text-center text-5xl font-bold tracking-normal sm:text-7xl">
          <span class="text-[#071632]">Triple</span><span class="text-[#05c7b2]">Talk</span>
        </h1>
      </div>
    </main>
  </body>
</html>
